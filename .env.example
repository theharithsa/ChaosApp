# Environment Configuration for ChaosApp
# Copy this to .env and fill in your values

# Application
PORT=3000
NODE_ENV=production

# Dynatrace Configuration
# Get these from your Dynatrace environment
DYNATRACE_URL=https://your-environment-id.live.dynatrace.com
DYNATRACE_TOKEN=dt0c01.your-api-token-here

# GitHub Configuration (for local testing)
GITHUB_TOKEN=ghp_your-github-token
GITHUB_OWNER=your-username
GITHUB_REPO=ChaosApp
